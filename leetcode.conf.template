PROBLEM_POSTGRES_DB=your_problem_postgres_db_name
PROBLEM_POSTGRES_USER=your_problem_postgres_username
PROBLEM_POSTGRES_PASSWORD=your_problem_postgres_password

PROBLEM_SPRING_DATASOURCE_URL=jdbc:postgresql://problem-postgres:5432/your_problem_postgres_db_name
