POSTGRES_USER=your_user_postgres_username
POSTGRES_PASSWORD=your_user_postgres_password

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/your_user_postgres_db_name
SPRING_DATASOURCE_USERNAME=your_user_postgres_username
SPRING_DATASOURCE_PASSWORD=your_user_postgres_password

##########################################
